{
  "name": "drdepo",
  "version": "3.0.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "migrate:firebase": "node migrate_db.cjs",
    "migrate:firebase:dry": "node migrate_db.cjs --dry-run",
    "verify:migration": "node scripts/verify-migration.cjs",
    "test": "npm run test:unit",
    "test:unit": "vitest run tests/unit tests/barcodeParser.test.js",
    "test:rules": "firebase emulators:exec --only firestore --config firebase.json \"vitest run tests/firestore.rules.test.js\"",
    "test:security": "npm audit --audit-level=moderate && npm run test:unit && npm run test:rules && npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/postcss": "^4.1.18",
    "firebase": "^12.7.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.562.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-webcam": "^7.2.0",
    "tesseract.js": "^5.0.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.23",
    "firebase-tools": "^15.22.4",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "vite": "^8.1.4",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "uuid": ">=11.1.1",
    "websocket-driver": "0.7.5"
  }
}
