rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validOptionalString(data, field, maxLength) {
      return !data.keys().hasAny([field]) ||
        (data[field] is string && data[field].size() <= maxLength);
    }

    function validExpiryDate(data) {
      return !data.keys().hasAny(['expiryDate']) ||
        (data.expiryDate is string &&
          data.expiryDate.size() <= 7 &&
          (data.expiryDate == '' || data.expiryDate.matches('^\\d{4}-(0[1-9]|1[0-2])$')));
    }

    function validCreatedAt(data) {
      return data.createdAt is string &&
        data.createdAt.size() >= 20 &&
        data.createdAt.size() <= 40 &&
        data.createdAt.matches('^\\d{4}-\\d{2}-\\d{2}T.*');
    }

    function validMedicine(data) {
      return data.keys().hasOnly([
          'name', 'quantity', 'expiryDate',
          'activeIngredient1', 'activeIngredient2', 'activeIngredient3',
          'notes', 'createdAt', 'tags', 'familyId', 'isPrivate', 'stockCount', 'barcode'
        ]) &&
        data.keys().hasAll(['name', 'createdAt']) &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 120 &&
        validOptionalString(data, 'quantity', 80) &&
        validOptionalString(data, 'activeIngredient1', 120) &&
        validOptionalString(data, 'activeIngredient2', 120) &&
        validOptionalString(data, 'activeIngredient3', 120) &&
        validOptionalString(data, 'notes', 500) &&
        validOptionalString(data, 'barcode', 64) &&
        validExpiryDate(data) &&
        validCreatedAt(data) &&
        (!data.keys().hasAny(['tags']) || data.tags is list) &&
        (!data.keys().hasAny(['isPrivate']) || data.isPrivate is bool) &&
        (!data.keys().hasAny(['familyId']) || data.familyId is string) &&
        (!data.keys().hasAny(['stockCount']) || (data.stockCount is int && data.stockCount >= 1 && data.stockCount <= 999));
    }

    function isFamilyMember(familyId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/families/$(familyId))
          .data.members.keys().hasAny([request.auth.uid]);
    }

    function isFamilyAdmin(familyId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/families/$(familyId))
          .data.members[request.auth.uid].role == 'admin';
    }

    function isFamilyEditor(userId) {
      let myDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      let theirDoc = get(/databases/$(database)/documents/users/$(userId));
      let fid = myDoc.data.familyId;
      return fid != null &&
             fid == theirDoc.data.familyId &&
             get(/databases/$(database)/documents/families/$(fid))
               .data.members[request.auth.uid].role in ['admin', 'editor'];
    }

    function validSelfJoin(familyId) {
      let diff = request.resource.data.diff(resource.data);
      let memberDiff = request.resource.data.members.diff(resource.data.members);
      let newMember = request.resource.data.members[request.auth.uid];
      let invite = getAfter(/databases/$(database)/documents/invites/$(newMember.inviteId));
      return diff.affectedKeys().hasOnly(['members']) &&
        memberDiff.addedKeys().hasOnly([request.auth.uid]) &&
        memberDiff.changedKeys().size() == 0 &&
        memberDiff.removedKeys().size() == 0 &&
        newMember.role == 'member' &&
        newMember.inviteId is string &&
        invite.data.familyId == familyId &&
        invite.data.status == 'accepted' &&
        invite.data.usedBy == request.auth.uid;
    }

    // QR daveti için özel kural: transaction içinde invite ve family aynı anda yazılır.
    // getAfter() transaction sonrası durumu okur → invite 'accepted' + usedBy = user olur.
    function validQrSelfJoin(familyId) {
      let diff = request.resource.data.diff(resource.data);
      let memberDiff = request.resource.data.members.diff(resource.data.members);
      let newMember = request.resource.data.members[request.auth.uid];
      let invite = getAfter(/databases/$(database)/documents/invites/$(newMember.inviteId));
      return diff.affectedKeys().hasOnly(['members']) &&
        memberDiff.addedKeys().hasOnly([request.auth.uid]) &&
        memberDiff.changedKeys().size() == 0 &&
        memberDiff.removedKeys().size() == 0 &&
        newMember.role == 'member' &&
        newMember.inviteId is string &&
        invite.data.type == 'qr' &&
        invite.data.familyId == familyId &&
        invite.data.usedBy == request.auth.uid;
    }

    function validSelfLeave() {
      let diff = request.resource.data.diff(resource.data);
      let memberDiff = request.resource.data.members.diff(resource.data.members);
      return diff.affectedKeys().hasOnly(['members']) &&
        memberDiff.removedKeys().hasOnly([request.auth.uid]) &&
        memberDiff.addedKeys().size() == 0 &&
        memberDiff.changedKeys().size() == 0;
    }

    function validOwnKeyringUpdate() {
      let diff = request.resource.data.diff(resource.data);
      let keyDiff = request.resource.data.familyKeyring.diff(resource.data.get('familyKeyring', {}));
      return diff.affectedKeys().hasOnly(['familyKeyring']) &&
        keyDiff.affectedKeys().hasOnly([request.auth.uid]) &&
        request.resource.data.familyKeyring[request.auth.uid] is map;
    }

    function isEmailInvite(data) {
      return !data.keys().hasAny(['type']) || data.type == 'email';
    }

    function isQrInvite(data) {
      return data.type == 'qr';
    }

    function validEmailInviteCreate(data) {
      return data.keys().hasOnly(['type', 'familyId', 'familyName', 'invitedEmail', 'invitedBy', 'createdBy', 'status', 'createdAt', 'expiresAt']) &&
        data.type == 'email' &&
        data.familyId is string &&
        data.familyName is string &&
        data.invitedEmail is string &&
        data.invitedBy is string &&
        data.createdBy == request.auth.uid &&
        data.status == 'pending' &&
        data.createdAt is string &&
        data.expiresAt is string &&
        isFamilyAdmin(data.familyId);
    }

    function validQrInviteCreate(data) {
      return data.keys().hasOnly(['type', 'familyId', 'familyName', 'createdBy', 'status', 'encryptedFamilyKey', 'createdAt', 'expiresAt', 'usedBy', 'usedAt']) &&
        data.type == 'qr' &&
        data.familyId is string &&
        data.familyName is string &&
        data.createdBy == request.auth.uid &&
        data.status == 'pending' &&
        data.encryptedFamilyKey is map &&
        data.createdAt is string &&
        data.expiresAt is string &&
        data.usedBy == null &&
        data.usedAt == null &&
        isFamilyAdmin(data.familyId);
    }

    function validInviteStatusUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'usedBy', 'usedAt']) &&
        request.resource.data.usedAt is string;
    }

    match /users/{userId}/medicines/{medicineId} {
      allow read: if isOwner(userId) ||
        (isSignedIn() &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId ==
          get(/databases/$(database)/documents/users/$(userId)).data.familyId &&
          resource.data.get('isPrivate', false) != true);
      allow create: if isOwner(userId) && validMedicine(request.resource.data);
      allow update: if (isOwner(userId) || (isSignedIn() && !isOwner(userId) && isFamilyEditor(userId) && resource.data.get('isPrivate', false) != true)) &&
        validMedicine(request.resource.data) &&
        (
          (resource.data.keys().hasAny(['createdAt']) &&
            request.resource.data.createdAt == resource.data.createdAt) ||
          (!resource.data.keys().hasAny(['createdAt']) && validCreatedAt(request.resource.data))
        );
      allow delete: if isOwner(userId);

      match /usageLog/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) &&
          request.resource.data.keys().hasOnly(['action', 'note', 'createdAt']) &&
          request.resource.data.action in ['used', 'finished', 'added', 'edited'] &&
          (!request.resource.data.keys().hasAny(['note']) || request.resource.data.note is string);
        allow delete: if isOwner(userId);
      }
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/pushSubscriptions/{subId} {
      allow read, write, delete: if isOwner(userId);
    }

    match /families/{familyId} {
      allow read: if isFamilyMember(familyId);
      allow create: if isSignedIn() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.members.keys().hasOnly([request.auth.uid]);
      allow update: if isFamilyAdmin(familyId) || validSelfJoin(familyId) || validQrSelfJoin(familyId) || validSelfLeave() || (isFamilyMember(familyId) && validOwnKeyringUpdate());
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    match /invites/{inviteId} {
      allow get: if isSignedIn() && (
        (isEmailInvite(resource.data) && resource.data.invitedEmail == request.auth.token.email) ||
        (isQrInvite(resource.data) && resource.data.status == 'pending') ||
        resource.data.createdBy == request.auth.uid
      );
      allow list: if isSignedIn() &&
        isEmailInvite(resource.data) &&
        resource.data.invitedEmail == request.auth.token.email;
      allow create: if isSignedIn() &&
        (validEmailInviteCreate(request.resource.data) || validQrInviteCreate(request.resource.data));
      allow update: if isSignedIn() && (
        (
          isEmailInvite(resource.data) &&
          resource.data.status == 'pending' &&
          resource.data.invitedEmail == request.auth.token.email &&
          request.resource.data.status in ['accepted', 'rejected'] &&
          (request.resource.data.status == 'rejected' || request.resource.data.usedBy == request.auth.uid) &&
          validInviteStatusUpdate()
        ) ||
        (
          isQrInvite(resource.data) &&
          resource.data.status == 'pending' &&
          request.resource.data.status == 'accepted' &&
          request.resource.data.usedBy == request.auth.uid &&
          validInviteStatusUpdate()
        )
      );
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    match /sharedLinks/{token} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasOnly(['userId', 'medicineId', 'expiresAt', 'createdAt', 'medicine']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
